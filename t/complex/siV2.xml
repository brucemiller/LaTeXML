  <subsection inlist="toc" xml:id="S5.SS5">
    <tags>
      <tag>5.5</tag>
      <tag role="refnum">5.5</tag>
      <tag role="typerefnum">§5.5</tag>
    </tags>
    <title><tag close=" ">5.5</tag>Post-processing numbers</title>
    <subsubsection inlist="toc" xml:id="S5.SS5.SSS1">
      <tags>
        <tag>5.5.1</tag>
        <tag role="refnum">5.5.1</tag>
        <tag role="typerefnum">§5.5.1</tag>
      </tags>
      <title><tag close=" ">5.5.1</tag>add-decimal-zero</title>
      <para xml:id="S5.SS5.SSS1.p1">
        <p><Math mode="inline" tex="10.0" text="10.0" xml:id="S5.SS5.SSS1.p1.m1">
            <XMath>
              <XMTok meaning="10.0" role="NUMBER">10.0</XMTok>
            </XMath>
          </Math><break/><Math mode="inline" tex="123." text="123" xml:id="S5.SS5.SSS1.p1.m2">
            <XMath>
              <XMDual>
                <XMTok meaning="123" role="NUMBER"/>
                <XMWrap>
                  <XMTok meaning="123" role="NUMBER">123</XMTok>
                  <XMTok role="PERIOD">.</XMTok>
                </XMWrap>
              </XMDual>
            </XMath>
          </Math></p>
      </para>
    </subsubsection>
  </subsection>
  <subsection inlist="toc" xml:id="S5.SS6">
    <tags>
      <tag>5.6</tag>
      <tag role="refnum">5.6</tag>
      <tag role="typerefnum">§5.6</tag>
    </tags>
    <title><tag close=" ">5.6</tag>Printing numbers</title>
    <subsubsection inlist="toc" xml:id="S5.SS6.SSS1">
      <tags>
        <tag>5.6.1</tag>
        <tag role="refnum">5.6.1</tag>
        <tag role="typerefnum">§5.6.1</tag>
      </tags>
      <title><tag close=" ">5.6.1</tag>group-four-digits</title>
      <para xml:id="S5.SS6.SSS1.p1">
        <p><Math mode="inline" tex="12\,3456\,7890.1234\,5678\,90" text="1234567890.1234567890" xml:id="S5.SS6.SSS1.p1.m1">
            <XMath>
              <XMTok meaning="1234567890.1234567890" role="NUMBER">12 3456 7890.1234 5678 90</XMTok>
            </XMath>
          </Math></p>
      </para>
    </subsubsection>
    <subsubsection inlist="toc" xml:id="S5.SS6.SSS2">
      <tags>
        <tag>5.6.2</tag>
        <tag role="refnum">5.6.2</tag>
        <tag role="typerefnum">§5.6.2</tag>
      </tags>
      <title><tag close=" ">5.6.2</tag>copy-complex-root, copy-decimal-marker</title>
      <para xml:id="S5.SS6.SSS2.p1">
        <p><Math mode="inline" tex="1+2\text{j}" text="1 + 2 * imaginary-unit" xml:id="S5.SS6.SSS2.p1.m1">
            <XMath>
              <XMApp>
                <XMTok meaning="plus" role="ADDOP" xml:id="S5.SS6.SSS2.p1.m1.2">+</XMTok>
                <XMTok meaning="1" role="NUMBER" xml:id="S5.SS6.SSS2.p1.m1.1">1</XMTok>
                <XMApp xml:id="S5.SS6.SSS2.p1.m1.3">
                  <XMTok meaning="times" role="MULOP" xml:id="S5.SS6.SSS2.p1.m1.3.2">⁢</XMTok>
                  <XMTok meaning="2" role="NUMBER" xml:id="S5.SS6.SSS2.p1.m1.3.1">2</XMTok>
                  <XMText meaning="imaginary-unit" role="ID" xml:id="S5.SS6.SSS2.p1.m1.3.3">j</XMText>
                </XMApp>
              </XMApp>
            </XMath>
          </Math><break/><Math mode="inline" tex="555,555" text="555.555" xml:id="S5.SS6.SSS2.p1.m2">
            <XMath>
              <XMDual>
                <XMTok meaning="555.555" role="NUMBER"/>
                <XMWrap>
                  <XMTok meaning="555" role="NUMBER" xml:id="S5.SS6.SSS2.p1.m2.1">555</XMTok>
                  <XMTok role="PUNCT">,</XMTok>
                  <XMTok meaning="555" role="NUMBER" xml:id="S5.SS6.SSS2.p1.m2.2">555</XMTok>
                </XMWrap>
              </XMDual>
            </XMath>
          </Math></p>
      </para>
    </subsubsection>
  </subsection>
  <subsection inlist="toc" xml:id="S5.SS7">
    <tags>
      <tag>5.7</tag>
      <tag role="refnum">5.7</tag>
      <tag role="typerefnum">§5.7</tag>
    </tags>
    <title><tag close=" ">5.7</tag>Multi-part numbers</title>
    <subsubsection inlist="toc" xml:id="S5.SS7.SSS1">
      <tags>
        <tag>5.7.1</tag>
        <tag role="refnum">5.7.1</tag>
        <tag role="typerefnum">§5.7.1</tag>
      </tags>
      <title><tag close=" ">5.7.1</tag>input-quotient</title>
      <para xml:id="S5.SS7.SSS1.p1">
        <p><Math mode="inline" tex="1\text{/}(2\text{\times}{10}^{4})" text="1 / 2E4" xml:id="S5.SS7.SSS1.p1.m1">
            <XMath>
              <XMApp>
                <XMText meaning="divide" role="MULOP" xml:id="S5.SS7.SSS1.p1.m1.2">/</XMText>
                <XMTok meaning="1" role="NUMBER" xml:id="S5.SS7.SSS1.p1.m1.1">1</XMTok>
                <XMDual meaning="2E4" xml:id="S5.SS7.SSS1.p1.m1.3">
                  <XMApp>
                    <XMRef idref="S5.SS7.SSS1.p1.m1.3.2"/>
                    <XMRef idref="S5.SS7.SSS1.p1.m1.3.1"/>
                    <XMRef idref="S5.SS7.SSS1.p1.m1.3.3"/>
                  </XMApp>
                  <XMWrap>
                    <XMTok role="OPEN" stretchy="false">(</XMTok>
                    <XMApp xml:id="S5.SS7.SSS1.p1.m1.3.4">
                      <XMText meaning="times" role="MULOP" xml:id="S5.SS7.SSS1.p1.m1.3.2">×</XMText>
                      <XMTok meaning="2" role="NUMBER" xml:id="S5.SS7.SSS1.p1.m1.3.1">2</XMTok>
                      <XMApp xml:id="S5.SS7.SSS1.p1.m1.3.3">
                        <XMTok meaning="power" role="SUPERSCRIPTOP" scriptpos="post1"/>
                        <XMTok meaning="10" role="NUMBER">10</XMTok>
                        <XMTok fontsize="70%" meaning="4" role="NUMBER">4</XMTok>
                      </XMApp>
                    </XMApp>
                    <XMTok role="CLOSE" stretchy="false">)</XMTok>
                  </XMWrap>
                </XMDual>
              </XMApp>
            </XMath>
          </Math> <break/><Math mode="inline" tex="1\text{\times}{10}^{2}\text{/}(3\text{\times}{10}^{4})" text="1E2 / 3E4" xml:id="S5.SS7.SSS1.p1.m2">
            <XMath>
              <XMApp>
                <XMText meaning="divide" role="MULOP" xml:id="S5.SS7.SSS1.p1.m2.2">/</XMText>
                <XMApp meaning="1E2" xml:id="S5.SS7.SSS1.p1.m2.1">
                  <XMText meaning="times" role="MULOP" xml:id="S5.SS7.SSS1.p1.m2.1.2">×</XMText>
                  <XMTok meaning="1" role="NUMBER" xml:id="S5.SS7.SSS1.p1.m2.1.1">1</XMTok>
                  <XMApp xml:id="S5.SS7.SSS1.p1.m2.1.3">
                    <XMTok meaning="power" role="SUPERSCRIPTOP" scriptpos="post1"/>
                    <XMTok meaning="10" role="NUMBER">10</XMTok>
                    <XMTok fontsize="70%" meaning="2" role="NUMBER">2</XMTok>
                  </XMApp>
                </XMApp>
                <XMDual meaning="3E4" xml:id="S5.SS7.SSS1.p1.m2.3">
                  <XMApp>
                    <XMRef idref="S5.SS7.SSS1.p1.m2.3.2"/>
                    <XMRef idref="S5.SS7.SSS1.p1.m2.3.1"/>
                    <XMRef idref="S5.SS7.SSS1.p1.m2.3.3"/>
                  </XMApp>
                  <XMWrap>
                    <XMTok role="OPEN" stretchy="false">(</XMTok>
                    <XMApp xml:id="S5.SS7.SSS1.p1.m2.3.4">
                      <XMText meaning="times" role="MULOP" xml:id="S5.SS7.SSS1.p1.m2.3.2">×</XMText>
                      <XMTok meaning="3" role="NUMBER" xml:id="S5.SS7.SSS1.p1.m2.3.1">3</XMTok>
                      <XMApp xml:id="S5.SS7.SSS1.p1.m2.3.3">
                        <XMTok meaning="power" role="SUPERSCRIPTOP" scriptpos="post1"/>
                        <XMTok meaning="10" role="NUMBER">10</XMTok>
                        <XMTok fontsize="70%" meaning="4" role="NUMBER">4</XMTok>
                      </XMApp>
                    </XMApp>
                    <XMTok role="CLOSE" stretchy="false">)</XMTok>
                  </XMWrap>
                </XMDual>
              </XMApp>
            </XMath>
          </Math><break/><Math mode="inline" tex="1\text{\times}{10}^{2}\text{/}(3\text{\times}{10}^{4})" text="1E2 / 3E4" xml:id="S5.SS7.SSS1.p1.m3">
            <XMath>
              <XMApp>
                <XMText meaning="divide" role="MULOP" xml:id="S5.SS7.SSS1.p1.m3.2">/</XMText>
                <XMApp meaning="1E2" xml:id="S5.SS7.SSS1.p1.m3.1">
                  <XMText meaning="times" role="MULOP" xml:id="S5.SS7.SSS1.p1.m3.1.2">×</XMText>
                  <XMTok meaning="1" role="NUMBER" xml:id="S5.SS7.SSS1.p1.m3.1.1">1</XMTok>
                  <XMApp xml:id="S5.SS7.SSS1.p1.m3.1.3">
                    <XMTok meaning="power" role="SUPERSCRIPTOP" scriptpos="post1"/>
                    <XMTok meaning="10" role="NUMBER">10</XMTok>
                    <XMTok fontsize="70%" meaning="2" role="NUMBER">2</XMTok>
                  </XMApp>
                </XMApp>
                <XMDual meaning="3E4" xml:id="S5.SS7.SSS1.p1.m3.3">
                  <XMApp>
                    <XMRef idref="S5.SS7.SSS1.p1.m3.3.2"/>
                    <XMRef idref="S5.SS7.SSS1.p1.m3.3.1"/>
                    <XMRef idref="S5.SS7.SSS1.p1.m3.3.3"/>
                  </XMApp>
                  <XMWrap>
                    <XMTok role="OPEN" stretchy="false">(</XMTok>
                    <XMApp xml:id="S5.SS7.SSS1.p1.m3.3.4">
                      <XMText meaning="times" role="MULOP" xml:id="S5.SS7.SSS1.p1.m3.3.2">×</XMText>
                      <XMTok meaning="3" role="NUMBER" xml:id="S5.SS7.SSS1.p1.m3.3.1">3</XMTok>
                      <XMApp xml:id="S5.SS7.SSS1.p1.m3.3.3">
                        <XMTok meaning="power" role="SUPERSCRIPTOP" scriptpos="post1"/>
                        <XMTok meaning="10" role="NUMBER">10</XMTok>
                        <XMTok fontsize="70%" meaning="4" role="NUMBER">4</XMTok>
                      </XMApp>
                    </XMApp>
                    <XMTok role="CLOSE" stretchy="false">)</XMTok>
                  </XMWrap>
                </XMDual>
              </XMApp>
            </XMath>
          </Math></p>
      </para>
    </subsubsection>
    <subsubsection inlist="toc" xml:id="S5.SS7.SSS2">
      <tags>
        <tag>5.7.2</tag>
        <tag role="refnum">5.7.2</tag>
        <tag role="typerefnum">§5.7.2</tag>
      </tags>
      <title><tag close=" ">5.7.2</tag>output-quotient</title>
      <para xml:id="S5.SS7.SSS2.p1">
        <p><Math mode="inline" tex="1\text{\text{ div }}2" text="1 / 2" xml:id="S5.SS7.SSS2.p1.m1">
            <XMath>
              <XMApp>
                <XMText meaning="divide" role="MULOP" xml:id="S5.SS7.SSS2.p1.m1.2"> div </XMText>
                <XMTok meaning="1" role="NUMBER" xml:id="S5.SS7.SSS2.p1.m1.1">1</XMTok>
                <XMTok meaning="2" role="NUMBER" xml:id="S5.SS7.SSS2.p1.m1.3">2</XMTok>
              </XMApp>
            </XMath>
          </Math></p>
      </para>
    </subsubsection>
    <subsubsection inlist="toc" xml:id="S5.SS7.SSS3">
      <tags>
        <tag>5.7.3</tag>
        <tag role="refnum">5.7.3</tag>
        <tag role="typerefnum">§5.7.3</tag>
      </tags>
      <title><tag close=" ">5.7.3</tag>quotient-mode</title>
      <para xml:id="S5.SS7.SSS3.p1">
        <p><Math mode="inline" tex="1\text{/}(2\text{\times}{10}^{4})" text="1 / 2E4" xml:id="S5.SS7.SSS3.p1.m1">
            <XMath>
              <XMApp>
                <XMText meaning="divide" role="MULOP" xml:id="S5.SS7.SSS3.p1.m1.2">/</XMText>
                <XMTok meaning="1" role="NUMBER" xml:id="S5.SS7.SSS3.p1.m1.1">1</XMTok>
                <XMDual meaning="2E4" xml:id="S5.SS7.SSS3.p1.m1.3">
                  <XMApp>
                    <XMRef idref="S5.SS7.SSS3.p1.m1.3.2"/>
                    <XMRef idref="S5.SS7.SSS3.p1.m1.3.1"/>
                    <XMRef idref="S5.SS7.SSS3.p1.m1.3.3"/>
                  </XMApp>
                  <XMWrap>
                    <XMTok role="OPEN" stretchy="false">(</XMTok>
                    <XMApp xml:id="S5.SS7.SSS3.p1.m1.3.4">
                      <XMText meaning="times" role="MULOP" xml:id="S5.SS7.SSS3.p1.m1.3.2">×</XMText>
                      <XMTok meaning="2" role="NUMBER" xml:id="S5.SS7.SSS3.p1.m1.3.1">2</XMTok>
                      <XMApp xml:id="S5.SS7.SSS3.p1.m1.3.3">
                        <XMTok meaning="power" role="SUPERSCRIPTOP" scriptpos="post1"/>
                        <XMTok meaning="10" role="NUMBER">10</XMTok>
                        <XMTok fontsize="70%" meaning="4" role="NUMBER">4</XMTok>
                      </XMApp>
                    </XMApp>
                    <XMTok role="CLOSE" stretchy="false">)</XMTok>
                  </XMWrap>
                </XMDual>
              </XMApp>
            </XMath>
          </Math> <break/><Math mode="inline" tex="\frac{1}{2\text{\times}{10}^{4}}" text="1 / 2E4" xml:id="S5.SS7.SSS3.p1.m2">
            <XMath>
              <XMApp>
                <XMTok mathstyle="text" meaning="divide" role="FRACOP"/>
                <XMTok fontsize="70%" meaning="1" role="NUMBER">1</XMTok>
                <XMApp meaning="2E4">
                  <XMText meaning="times" role="MULOP" xml:id="S5.SS7.SSS3.p1.m2.2"><text fontsize="70%">×</text></XMText>
                  <XMTok fontsize="70%" meaning="2" role="NUMBER" xml:id="S5.SS7.SSS3.p1.m2.1">2</XMTok>
                  <XMApp xml:id="S5.SS7.SSS3.p1.m2.3">
                    <XMTok meaning="power" role="SUPERSCRIPTOP" scriptpos="post2"/>
                    <XMTok fontsize="70%" meaning="10" role="NUMBER">10</XMTok>
                    <XMTok fontsize="50%" meaning="4" role="NUMBER">4</XMTok>
                  </XMApp>
                </XMApp>
              </XMApp>
            </XMath>
          </Math></p>
      </para>
    </subsubsection>
    <subsubsection inlist="toc" xml:id="S5.SS7.SSS4">
      <tags>
        <tag>5.7.4</tag>
        <tag role="refnum">5.7.4</tag>
        <tag role="typerefnum">§5.7.4</tag>
      </tags>
      <title><tag close=" ">5.7.4</tag>fraction-function</title>
      <para xml:id="S5.SS7.SSS4.p1">
        <p><Math mode="inline" tex="\frac{1}{1}" text="1 / 1" xml:id="S5.SS7.SSS4.p1.m1">
            <XMath>
              <XMApp>
                <XMTok mathstyle="text" meaning="divide" role="FRACOP"/>
                <XMTok fontsize="70%" meaning="1" role="NUMBER">1</XMTok>
                <XMTok fontsize="70%" meaning="1" role="NUMBER">1</XMTok>
              </XMApp>
            </XMath>
          </Math><break/><Math mode="inline" tex="\dfrac{1}{2}" text="1 / 2" xml:id="S5.SS7.SSS4.p1.m2">
            <XMath>
              <XMApp>
                <XMTok mathstyle="display" meaning="divide" role="FRACOP"/>
                <XMTok meaning="1" role="NUMBER">1</XMTok>
                <XMTok meaning="2" role="NUMBER">2</XMTok>
              </XMApp>
            </XMath>
          </Math><break/><Math mode="inline" tex="\tfrac{1}{4}" text="1 / 4" xml:id="S5.SS7.SSS4.p1.m3">
            <XMath>
              <XMApp>
                <XMTok mathstyle="text" meaning="divide" role="FRACOP"/>
                <XMTok fontsize="70%" meaning="1" role="NUMBER">1</XMTok>
                <XMTok fontsize="70%" meaning="4" role="NUMBER">4</XMTok>
              </XMApp>
            </XMath>
          </Math></p>
      </para>
    </subsubsection>
  </subsection>
  <subsection inlist="toc" xml:id="S5.SS12">
    <tags>
      <tag>5.12</tag>
      <tag role="refnum">5.12</tag>
      <tag role="typerefnum">§5.12</tag>
    </tags>
    <title><tag close=" ">5.12</tag>Using units</title>
    <subsubsection inlist="toc" xml:id="S5.SS12.SSS1">
      <tags>
        <tag>5.12.1</tag>
        <tag role="refnum">5.12.1</tag>
        <tag role="typerefnum">§5.12.1</tag>
      </tags>
      <title><tag close=" ">5.12.1</tag>qualifier-mode</title>
      <para xml:id="S5.SS12.SSS1.p1">
        <p><Math mode="inline" tex="{\mathrm{(kgof\mathrm{pol})}}^{2}\text{\,}{\mathrm{(molof\mathrm{cat})}}^{-1}%&#10;\text{\,}{\mathrm{h}}^{-1}" text="power@(kilogram-polymer, 2) * power@(mole-catalyst, - 1) * power@(hour, - 1)" xml:id="S5.SS12.SSS1.p1.m1">
            <XMath>
              <XMApp>
                <XMText meaning="times" role="MULOP" xml:id="S5.SS12.SSS1.p1.m1.4"> </XMText>
                <XMApp xml:id="S5.SS12.SSS1.p1.m1.1">
                  <XMTok meaning="power" role="SUPERSCRIPTOP" scriptpos="post1"/>
                  <XMDual class="ltx_unit" meaning="kilogram-polymer" role="ID">
                    <XMRef idref="S5.SS12.SSS1.p1.m1.1.1"/>
                    <XMWrap>
                      <XMTok role="OPEN" stretchy="false">(</XMTok>
                      <XMTok role="UNKNOWN" xml:id="S5.SS12.SSS1.p1.m1.1.1">kgofpol</XMTok>
                      <XMTok role="CLOSE" stretchy="false">)</XMTok>
                    </XMWrap>
                  </XMDual>
                  <XMTok fontsize="70%" meaning="2" role="NUMBER">2</XMTok>
                </XMApp>
                <XMApp xml:id="S5.SS12.SSS1.p1.m1.3">
                  <XMTok meaning="power" role="SUPERSCRIPTOP" scriptpos="post1"/>
                  <XMDual class="ltx_unit" meaning="mole-catalyst" role="ID">
                    <XMRef idref="S5.SS12.SSS1.p1.m1.3.1"/>
                    <XMWrap>
                      <XMTok role="OPEN" stretchy="false">(</XMTok>
                      <XMTok role="UNKNOWN" xml:id="S5.SS12.SSS1.p1.m1.3.1">molofcat</XMTok>
                      <XMTok role="CLOSE" stretchy="false">)</XMTok>
                    </XMWrap>
                  </XMDual>
                  <XMApp>
                    <XMTok fontsize="70%" meaning="minus" role="ADDOP">-</XMTok>
                    <XMTok fontsize="70%" meaning="1" role="NUMBER">1</XMTok>
                  </XMApp>
                </XMApp>
                <XMApp xml:id="S5.SS12.SSS1.p1.m1.5">
                  <XMTok meaning="power" role="SUPERSCRIPTOP" scriptpos="post1"/>
                  <XMTok class="ltx_unit" meaning="hour" role="ID">h</XMTok>
                  <XMApp>
                    <XMTok fontsize="70%" meaning="minus" role="ADDOP">-</XMTok>
                    <XMTok fontsize="70%" meaning="1" role="NUMBER">1</XMTok>
                  </XMApp>
                </XMApp>
              </XMApp>
            </XMath>
          </Math></p>
      </para>
      <table inlist="lot" labels="LABEL:tab:s:demo" xml:id="S5.T1">
        <tags>
          <tag>Table 1</tag>
          <tag role="refnum">1</tag>
          <tag role="typerefnum">Table 1</tag>
        </tags>
        <toccaption class="ltx_centering"><tag close=" ">1</tag>Units in tables.</toccaption>
        <caption class="ltx_centering"><tag close=": ">Table 1</tag>Units in tables.</caption>
        <tabular class="ltx_centering ltx_guessed_headers" vattach="middle">
          <thead>
            <tr>
              <td align="center" border="tt" thead="column">Unit</td>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td align="left" border="t"><Math mode="inline" tex="{\mathrm{m}}^{2}\text{\,}{\mathrm{s}}^{-1}" text="power@(meter, 2) * power@(second, - 1)" xml:id="S5.T1.m1">
                  <XMath>
                    <XMApp>
                      <XMText meaning="times" role="MULOP" xml:id="S5.T1.m1.2"> </XMText>
                      <XMApp xml:id="S5.T1.m1.1">
                        <XMTok meaning="power" role="SUPERSCRIPTOP" scriptpos="post1"/>
                        <XMTok class="ltx_unit" meaning="meter" role="ID">m</XMTok>
                        <XMTok fontsize="70%" meaning="2" role="NUMBER">2</XMTok>
                      </XMApp>
                      <XMApp xml:id="S5.T1.m1.3">
                        <XMTok meaning="power" role="SUPERSCRIPTOP" scriptpos="post1"/>
                        <XMTok class="ltx_unit" meaning="second" role="ID">s</XMTok>
