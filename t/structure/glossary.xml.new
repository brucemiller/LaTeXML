    <glossaryphrase key="svm" role="name">SVM</glossaryphrase>
    <glossaryphrase key="svm" role="short">SVM</glossaryphrase>
    <glossaryphrase key="svm" role="shortplural">SVMs</glossaryphrase>
    <glossaryphrase key="svm" role="sort">SVM</glossaryphrase>
    <glossaryphrase key="svm" role="text">SVM</glossaryphrase>
  </glossarydefinition>
  <section inlist="toc" xml:id="S1">
    <tags>
      <tag>1</tag>
      <tag role="refnum">1</tag>
      <tag role="typerefnum">¬ß1</tag>
    </tags>
    <title><tag close=" ">1</tag>Using Acronyms</title>
    <para xml:id="S1.p1">
      <p>Acronym first use: <glossaryref inlist="acronym" key="svm">support vector machine (SVM)</glossaryref>. Second use: <glossaryref inlist="acronym" key="svm">SVM</glossaryref>. A use <glossaryref inlist="acronym" key="svm">SVM</glossaryref> within a sentence.</p>
    </para>
  </section>
  <section inlist="toc" xml:id="S2">
    <tags>
      <tag>2</tag>
      <tag role="refnum">2</tag>
      <tag role="typerefnum">¬ß2</tag>
    </tags>
    <title><tag close=" ">2</tag>Using Glossaries</title>
    <para xml:id="S2.p1">
      <p>Glossary use, various cases:</p>
      <itemize xml:id="S2.I1">
        <item xml:id="S2.I1.i1">
          <tags>
            <tag>‚ÄĘ</tag>
            <tag role="typerefnum">1st item</tag>
          </tags>
          <para xml:id="S2.I1.i1.p1">
            <p>Chop the <glossaryref inlist="main" key="cabbage">cabbage</glossaryref>, <glossaryref inlist="main" key="potato"><!--  %‚Äútracingmacros=2‚Äúrelax -->potatoes<!--  %‚Äútracingcommands=2‚Äúrelax 
     %‚Äúnewglossaryentry‚ÄďpooňĚ‚Äďname=‚ÄďpooňĚ,description=‚ÄďdoodooňĚňĚ 
     %‚Äútracingmacros=0‚Äúrelax 
     %‚Äútracingcommands=0‚Äúrelax 
     %‚Äútracingmacros=2‚Äúrelax 
     %‚Äútracingcommands=2‚Äúrelax 
     %‚Äúnewglossaryentry‚ÄďpooňĚ‚Äďname=‚ÄďpooňĚ,description=‚ÄďdoodooňĚňĚ 
     %‚Äútracingmacros=0‚Äúrelax 
     %‚Äútracingcommands=0‚Äúrelax --></glossaryref><!--  %‚Äútracingmacros=2‚Äúrelax 
     %‚Äútracingcommands=2‚Äúrelax 
     %‚Äúnewglossaryentry‚ÄďpooňĚ‚Äďname=‚ÄďpooňĚ,description=‚ÄďdoodooňĚňĚ 
     %‚Äútracingmacros=0‚Äúrelax 
     %‚Äútracingcommands=0‚Äúrelax 
     %‚Äútracingmacros=2‚Äúrelax 
     %‚Äútracingcommands=2‚Äúrelax 
     %‚Äúnewglossaryentry‚ÄďpooňĚ‚Äďname=‚ÄďpooňĚ,description=‚ÄďdoodooňĚňĚ 
     %‚Äútracingmacros=0‚Äúrelax 
     %‚Äútracingcommands=0‚Äúrelax --> and <glossaryref inlist="main" key="carrot">carrots</glossaryref>.</p>
          </para>
        </item>
        <item xml:id="S2.I1.i2">
          <tags>
            <tag>‚ÄĘ</tag>
            <tag role="typerefnum">2nd item</tag>
          </tags>
          <para xml:id="S2.I1.i2.p1">
            <p>Or, more loudly: Chop the <glossaryref inlist="main" key="cabbage">Cabbage</glossaryref>, <glossaryref inlist="main" key="potato">Potatoes</glossaryref><!--  %‚Äútracingmacros=2‚Äúrelax 
     %‚Äútracingcommands=2‚Äúrelax 
     %‚Äúnewglossaryentry‚ÄďpooňĚ‚Äďname=‚ÄďpooňĚ,description=‚ÄďdoodooňĚňĚ 
     %‚Äútracingmacros=0‚Äúrelax 
     %‚Äútracingcommands=0‚Äúrelax 
     %‚Äútracingmacros=2‚Äúrelax 
     %‚Äútracingcommands=2‚Äúrelax 
     %‚Äúnewglossaryentry‚ÄďpooňĚ‚Äďname=‚ÄďpooňĚ,description=‚ÄďdoodooňĚňĚ 
     %‚Äútracingmacros=0‚Äúrelax 
     %‚Äútracingcommands=0‚Äúrelax --> and <glossaryref inlist="main" key="carrot">Carrots</glossaryref><!--  %texlive 2023 appears to differ on ‚ÄúGLS as it keeps the argument lowercased? -->.
<!--  %‚Äúitem Or, more loudly: Chop the ‚ÄúGLS‚ÄďcabbageňĚ, ‚ÄúGLSpl‚ÄďpotatoňĚ and ‚ÄúGLSpl‚ÄďcarrotňĚ. --></p>
          </para>
        </item>
        <item xml:id="S2.I1.i3">
          <tags>
            <tag>‚ÄĘ</tag>
            <tag role="typerefnum">3rd item</tag>
          </tags>
          <para xml:id="S2.I1.i3.p1">
            <p>For a small appetite, use only one, <glossaryref inlist="main" key="potato">potato</glossaryref><!--  %‚Äútracingmacros=2‚Äúrelax 
     %‚Äútracingcommands=2‚Äúrelax 
     %‚Äúnewglossaryentry‚ÄďpooňĚ‚Äďname=‚ÄďpooňĚ,description=‚ÄďdoodooňĚňĚ 
     %‚Äútracingmacros=0‚Äúrelax 
     %‚Äútracingcommands=0‚Äúrelax 
     %‚Äútracingmacros=2‚Äúrelax 
     %‚Äútracingcommands=2‚Äúrelax 
     %‚Äúnewglossaryentry‚ÄďpooňĚ‚Äďname=‚ÄďpooňĚ,description=‚ÄďdoodooňĚňĚ 
     %‚Äútracingmacros=0‚Äúrelax 
     %‚Äútracingcommands=0‚Äúrelax --> and <glossaryref inlist="main" key="carrot">carrot</glossaryref>.</p>
          </para>
        </item>
      </itemize>
    </para>
    <para xml:id="S2.p2">
      <p>But do not use the <glossaryref inlist="main" key="fishage">Fish Age</glossaryref>; that‚Äôs someething entirely different.
However, how about <glossaryref inlist="main" key="fishage"/>?</p>
    </para>
    <glossary lists="main" xml:id="glo.main">
      <title>Glossary</title>
    </glossary>
    <glossary lists="acronym" xml:id="glo.acronym">
      <title>Acronyms</title>
