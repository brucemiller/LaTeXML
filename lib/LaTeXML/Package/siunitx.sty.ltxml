  'uncertainty-descriptor-mode' => ['bracket', 'bracket-separator', 'separator', 'subscript'],
  'uncertainty-mode'            => ['compact', 'compact-marker',    'full',      'separate'],
  'uncertainty-round-direction' => ['down',    'nearest',           'up'],
