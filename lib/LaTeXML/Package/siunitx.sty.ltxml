use Data::Dumper;

# siunitx version 3 was released in May 2021.  I'm not sure which is in GitHub's TeXLive 2021
my $FMT_YEAR = Expand(T_CS('\fmtversion'))->toString;
$FMT_YEAR =~ s/\D.*//;
