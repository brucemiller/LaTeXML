# Distinguish THREE distinct use patterns!
#   \author{auth1\\affil1 \and ...}
#   \author[a]{auth1} ... \affil[a]{afill1} ...
#   \author{auth1}\afill{afill1} ...
DefMacro('\author[]{}', sub {
    my ($gullet, $mark, $author) = @_;
    if ($mark) {    # Use mark attachment
      Invocation(T_CS('\lx@authblk@author@marked'), $mark, $author); }
    elsif (grep { $_->defined_as(T_CS('\and')) || $_->defined_as(T_CS('\And')); } $author->unlist) {
      Invocation(T_CS('\lx@authblk@author@anded'), $author); }
    else {
      Invocation(T_CS('\lx@add@creator'), undef, $author); } });

DefMacro('\lx@authblk@author@marked{}{}', '\lx@add@creator[role=author,mark=#1]{#2}');
DefMacro('\lx@authblk@author@anded{}',
  '\lx@clear@creators[role=author]'
    # Note: must keep affiliations (after \\) embedded, to simplify clear@author removal
    . '\lx@splitting{\lx@author@and@affil}{\and,\And}{#1}');
# NOTE: Dangling <ltx:break> in affiliation???
DefMacro('\lx@author@and@affil{}', '\lx@author@and@affil@#1\\\\\done');
DefMacro('\lx@author@and@affil@ Until:\\\\ Until:\\done',
  '\ifx.#2.\lx@add@creator[role=author]{#1}'
    . '\else\lx@add@creator[role=author]{#1\lx@add@contact[role=affiliation]{#2}}\fi');

DefMacro('\affil[]{}',
  '\ifx.#1.\lx@add@contact[all=1,role=affiliation]{#2}'
    . '\else\lx@add@contact[mark=#1,role=affiliation]{#2}\fi');

# we shouldn't need these, but if someone is using them low-level
# might as well provide them
DefMacro('\AB@authnote{}',  '\textsuperscript{\normalfont#1}');
DefMacro('\AB@affilnote{}', '\textsuperscript{\normalfont#1}');

